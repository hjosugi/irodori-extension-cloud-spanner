{
  "schemaVersion": 1,
  "extensionId": "irodori.cloud-spanner",
  "visibility": "public",
  "version": "0.1.0",
  "connector": {
    "id": "cloudSpanner.connector",
    "engine": "cloudSpanner",
    "label": "Cloud Spanner",
    "aliases": [
      "cloudSpanner",
      "cloud-spanner",
      "Cloud Spanner",
      "Cloud",
      "Spanner"
    ],
    "defaultPort": 443,
    "wire": "cloudSpanner",
    "module": "cloudSpanner.driver",
    "features": [
      "metadata",
      "sql",
      "explain"
    ]
  },
  "connection": {
    "endpoint": {
      "modes": [
        "cloudResource",
        "connectionString"
      ],
      "defaultPort": 443,
      "fields": [
        {
          "id": "projectId",
          "label": "Google Cloud project",
          "type": "string",
          "profileField": "database",
          "required": true
        }
      ]
    },
    "authMethods": [
      "none",
      "connectionString",
      "oauthAccessToken",
      "serviceAccountJson",
      "serviceAccountJwt",
      "googleApplicationDefaultCredentials",
      "oauth2",
      "workloadIdentity",
      "customDriverOptions"
    ],
    "tls": "required",
    "transports": "default",
    "optionNamespaces": [
      "cloudSpanner",
      "googleCloud",
      "oauth"
    ],
    "customDriverOptions": true
  },
  "runtime": {
    "driverLinked": false
  },
  "source": {
    "knowledgeEngineStatus": "recognized_no_connector",
    "adapter": null
  }
}
