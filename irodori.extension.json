{
  "$schema": "https://irodori.dev/schemas/irodori.extension.schema.json",
  "manifestVersion": 1,
  "id": "irodori.cloud-spanner",
  "name": "Cloud Spanner Connector",
  "version": "0.1.0",
  "publisher": "irodori",
  "description": "Cloud Spanner Connector contributes the Cloud Spanner database connector through the native connector ABI.",
  "license": "MIT OR 0BSD",
  "repository": "https://github.com/hjosugi/irodori-extension-cloud-spanner",
  "apiVersion": "0.1",
  "runtime": "native",
  "entry": "dist/native",
  "permissions": [
    "connections:read",
    "connections:write",
    "queries:run",
    "metadata:read",
    "native",
    "connectors"
  ],
  "contributes": {
    "connectors": [
      {
        "id": "cloudSpanner.connector",
        "engine": "cloudSpanner",
        "label": "Cloud Spanner",
        "aliases": [
          "cloudSpanner",
          "cloud-spanner",
          "Cloud Spanner",
          "Cloud",
          "Spanner"
        ],
        "defaultPort": 443,
        "wire": "cloudSpanner",
        "module": "cloudSpanner.driver",
        "features": [
          "metadata",
          "sql",
          "explain"
        ],
        "connection": {
          "schemaVersion": 1,
          "inferEnvironmentFrom": [
            "name",
            "id",
            "host",
            "database",
            "url"
          ],
          "compatibility": {
            "addsRequiredProfileFields": false,
            "acceptsExistingProfiles": true
          },
          "defaults": {
            "engine": "cloudSpanner",
            "wire": "cloudSpanner",
            "port": 443,
            "readOnly": false
          },
          "endpoint": {
            "modes": [
              "cloudResource",
              "customEndpoint",
              "connectionString"
            ],
            "defaultPort": 443,
            "fields": [
              {
                "id": "projectId",
                "label": "Google Cloud project",
                "type": "string",
                "option": "projectId",
                "required": true
              },
              {
                "id": "instanceId",
                "label": "Spanner instance",
                "type": "string",
                "option": "instanceId",
                "required": true
              },
              {
                "id": "databaseId",
                "label": "Spanner database",
                "type": "string",
                "profileField": "database",
                "option": "databaseId",
                "required": true
              },
              {
                "id": "endpoint",
                "label": "Custom endpoint",
                "type": "uri",
                "profileField": "host",
                "option": "endpoint"
              }
            ]
          },
          "profileFields": [
            {
              "id": "id",
              "label": "Connection ID",
              "type": "string",
              "profileField": "id",
              "required": true
            },
            {
              "id": "url",
              "label": "Connection URL or DSN",
              "type": "uri",
              "profileField": "url"
            },
            {
              "id": "user",
              "label": "User",
              "type": "string",
              "profileField": "user"
            },
            {
              "id": "projectId",
              "label": "Google Cloud project",
              "type": "string",
              "option": "projectId",
              "required": true
            },
            {
              "id": "instanceId",
              "label": "Spanner instance",
              "type": "string",
              "option": "instanceId",
              "required": true
            },
            {
              "id": "databaseId",
              "label": "Spanner database",
              "type": "string",
              "profileField": "database",
              "option": "databaseId",
              "required": true
            },
            {
              "id": "endpoint",
              "label": "Custom endpoint",
              "type": "uri",
              "profileField": "host",
              "option": "endpoint"
            },
            {
              "id": "readOnly",
              "label": "Read-only connection",
              "type": "boolean",
              "profileField": "readOnly",
              "default": false
            },
            {
              "id": "options",
              "label": "Driver options",
              "type": "map",
              "profileField": "options"
            }
          ],
          "authMethods": [
            {
              "id": "none",
              "label": "No authentication",
              "kind": "none",
              "secretPurposes": [],
              "fields": []
            },
            {
              "id": "connectionString",
              "label": "Connection string / DSN",
              "kind": "connectionString",
              "secretPurposes": [],
              "fields": [
                {
                  "id": "url",
                  "label": "Connection URL or DSN",
                  "type": "uri",
                  "profileField": "url",
                  "required": true
                }
              ]
            },
            {
              "id": "oauthAccessToken",
              "label": "OAuth 2.0 access token",
              "kind": "token",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "token",
                  "label": "Token",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "serviceAccountJson",
              "label": "Service account JSON",
              "kind": "serviceAccount",
              "secretPurposes": [
                "privateKey"
              ],
              "fields": [
                {
                  "id": "serviceAccountJson",
                  "label": "Service account JSON",
                  "type": "json",
                  "secretPurpose": "privateKey"
                }
              ]
            },
            {
              "id": "serviceAccountJwt",
              "label": "Service account JWT private key",
              "kind": "privateKey",
              "secretPurposes": [
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "user",
                  "label": "User or client email",
                  "type": "string",
                  "profileField": "user"
                },
                {
                  "id": "privateKey",
                  "label": "Private key",
                  "type": "pem",
                  "secretPurpose": "privateKey"
                },
                {
                  "id": "privateKeyPassphrase",
                  "label": "Private key passphrase",
                  "type": "secret",
                  "secretPurpose": "privateKeyPassphrase"
                }
              ]
            },
            {
              "id": "googleApplicationDefaultCredentials",
              "label": "Application Default Credentials",
              "kind": "iam",
              "secretPurposes": [],
              "fields": []
            },
            {
              "id": "oauth2",
              "label": "OAuth 2.0",
              "kind": "oauth2",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "accessToken",
                  "label": "Access token",
                  "type": "secret",
                  "secretPurpose": "token"
                },
                {
                  "id": "refreshToken",
                  "label": "Refresh token",
                  "type": "secret",
                  "secretPurpose": "token"
                },
                {
                  "id": "clientId",
                  "label": "Client ID",
                  "type": "string"
                },
                {
                  "id": "clientSecret",
                  "label": "Client secret",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "workloadIdentity",
              "label": "Workload identity federation",
              "kind": "iam",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "credentialConfig",
                  "label": "Credential config",
                  "type": "json"
                },
                {
                  "id": "subjectToken",
                  "label": "Subject token",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "customDriverOptions",
              "label": "Custom driver options",
              "kind": "custom",
              "secretPurposes": [
                "password",
                "token",
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "options",
                  "label": "Driver options",
                  "type": "map",
                  "profileField": "options"
                }
              ]
            }
          ],
          "secretPurposes": [
            "token",
            "privateKey",
            "privateKeyPassphrase",
            "password"
          ],
          "tls": {
            "supported": true,
            "requiredByDefault": true,
            "modes": [
              "disable",
              "prefer",
              "require",
              "verifyCa",
              "verifyFull",
              "clientCertificate"
            ],
            "fields": [
              {
                "id": "caCertificate",
                "label": "CA certificate",
                "type": "pem"
              },
              {
                "id": "clientCertificate",
                "label": "Client certificate",
                "type": "pem"
              },
              {
                "id": "clientPrivateKey",
                "label": "Client private key",
                "type": "pem",
                "secretPurpose": "privateKey"
              }
            ]
          },
          "transports": [
            "direct",
            "sshTunnel",
            "socks5Proxy",
            "httpConnectProxy",
            "proxyChain"
          ],
          "optionNamespaces": [
            "profile.options",
            "driver",
            "tls",
            "network",
            "cloudSpanner",
            "googleCloud",
            "oauth"
          ],
          "customDriverOptions": true
        }
      }
    ]
  },
  "capabilities": {
    "nativeModules": [
      {
        "id": "cloudSpanner.driver",
        "path": "dist/native",
        "platforms": [
          "windowsX64",
          "windowsArm64",
          "macosX64",
          "macosArm64",
          "linuxX64",
          "linuxArm64"
        ]
      }
    ]
  },
  "dev": {
    "watch": [
      "src",
      "connector.config.json",
      "irodori.extension.json"
    ]
  }
}
